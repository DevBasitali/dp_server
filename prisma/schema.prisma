// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  owner
  branch_manager
  vendor
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password_hash String    @db.Text
  role          Role
  branch_id     String?   @db.Uuid
  vendor_id     String?   @db.Uuid
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  createdBy      String?   @db.Uuid
  accountStatus  String    @default("APPROVED") @db.VarChar(20)

  // Relations
  branch        Branch?   @relation("BranchManager", fields: [branch_id], references: [id])
  vendor        Vendor?   @relation("VendorUser", fields: [vendor_id], references: [id])

  purchases_recorded  Purchase[]           @relation("RecordedBy")
  payments_entered    PaymentInstallment[] @relation("PaymentEnteredBy")
  payments_deleted    PaymentInstallment[] @relation("PaymentDeletedBy")
  payment_edits       PaymentEditLog[]
  inventory_requests  InventoryRequest[]
  daily_sales         DailySale[]
  audit_logs          AuditLog[]           @relation("AuditLogActor")
  vendor_orders       VendorOrder[]        @relation("VendorOrderRequester")
  daily_closings      DailyClosing[]       @relation("DailyClosingEnterer")
  monthly_closings    MonthlyClosing[]     @relation("MonthlyClosingCloser")
  vendor_inventories  VendorInventory[]    @relation("VendorInventoryRecorder")
  vendor_payments     VendorPayment[]      @relation("VendorPaymentRecorder")

  // Owned-data back-relations
  owned_branches             Branch[]           @relation("OwnedBranches")
  owned_vendors              Vendor[]           @relation("OwnedVendors")
  owned_vendor_branch_links  VendorBranchLink[] @relation("OwnedVendorBranchLinks")
  owned_items                Item[]             @relation("OwnedItems")
  owned_vendor_orders        VendorOrder[]      @relation("OwnedVendorOrders")
  owned_daily_closings       DailyClosing[]     @relation("OwnedDailyClosings")
  owned_daily_expenses       DailyExpense[]     @relation("OwnedDailyExpenses")
  owned_monthly_closings     MonthlyClosing[]   @relation("OwnedMonthlyClosings")
  owned_cal_boxes            CalBox[]           @relation("OwnedCalBoxes")
  owned_vendor_inventories   VendorInventory[]  @relation("OwnedVendorInventories")
  owned_vendor_payments      VendorPayment[]    @relation("OwnedVendorPayments")
  owned_audit_logs           AuditLog[]         @relation("OwnedAuditLogs")
  owned_settings             SystemSetting[]    @relation("OwnedSettings")
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  location   String?  @db.Text
  manager_id String?  @db.Uuid
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  ownerId    String   @db.Uuid

  // Relations
  owner                User             @relation("OwnedBranches", fields: [ownerId], references: [id])
  managers             User[]           @relation("BranchManager")
  vendor_links         VendorBranchLink[]
  purchases            Purchase[]
  inventory_requests   InventoryRequest[]
  daily_sales          DailySale[]
  vendor_orders        VendorOrder[]
  daily_closings       DailyClosing[]
  monthly_closings     MonthlyClosing[]
  calBox               CalBox?
  vendor_inventories   VendorInventory[]
  vendor_payments      VendorPayment[]
}

model Vendor {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(100)
  phone           String?  @db.VarChar(20)
  whatsapp_number String   @db.VarChar(20)
  category        String?  @db.VarChar(100)
  notes           String?  @db.Text
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  ownerId         String   @db.Uuid

  // Relations
  owner               User             @relation("OwnedVendors", fields: [ownerId], references: [id])
  users               User[]           @relation("VendorUser")
  branch_links        VendorBranchLink[]
  items               Item[]
  purchases           Purchase[]
  inventory_requests  InventoryRequest[]
  vendor_orders       VendorOrder[]
  vendor_inventories  VendorInventory[]
  vendor_payments     VendorPayment[]
  daily_expenses      DailyExpense[]
}

model VendorBranchLink {
  id         String   @id @default(uuid()) @db.Uuid
  vendor_id  String   @db.Uuid
  branch_id  String   @db.Uuid
  created_at DateTime @default(now())
  ownerId    String   @db.Uuid

  owner      User     @relation("OwnedVendorBranchLinks", fields: [ownerId], references: [id])
  vendor     Vendor   @relation(fields: [vendor_id], references: [id])
  branch     Branch   @relation(fields: [branch_id], references: [id])
}

model Item {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(150)
  category       String?  @db.VarChar(100)
  vendor_id      String   @db.Uuid
  cost_price     Decimal  @db.Decimal(10, 2)
  selling_price  Decimal  @db.Decimal(10, 2)
  margin         Decimal  @db.Decimal(10, 2)
  margin_percent Decimal  @db.Decimal(5, 2)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  ownerId        String   @db.Uuid

  owner          User         @relation("OwnedItems", fields: [ownerId], references: [id])
  vendor         Vendor       @relation(fields: [vendor_id], references: [id])
  purchase_items PurchaseItem[]
}

model Purchase {
  id                String   @id @default(uuid()) @db.Uuid
  vendor_id         String   @db.Uuid
  branch_id         String   @db.Uuid
  total_amount      Decimal  @db.Decimal(12, 2)
  total_paid        Decimal  @db.Decimal(12, 2) @default(0)
  balance_remaining Decimal  @db.Decimal(12, 2)
  purchase_date     DateTime @db.Date
  invoice_number    String?  @db.VarChar(100)
  notes             String?  @db.Text
  recorded_by       String   @db.Uuid
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  vendor            Vendor   @relation(fields: [vendor_id], references: [id])
  branch            Branch   @relation(fields: [branch_id], references: [id])
  recorder          User     @relation("RecordedBy", fields: [recorded_by], references: [id])

  items             PurchaseItem[]
  payments          PaymentInstallment[]
}

model PurchaseItem {
  id                    String   @id @default(uuid()) @db.Uuid
  purchase_id           String   @db.Uuid
  item_id               String   @db.Uuid
  item_name             String   @db.VarChar(150)
  quantity              Int
  cost_price_at_purchase Decimal @db.Decimal(10, 2)
  line_total            Decimal  @db.Decimal(12, 2)
  created_at            DateTime @default(now())

  purchase              Purchase @relation(fields: [purchase_id], references: [id])
  item                  Item     @relation(fields: [item_id], references: [id])
}

model PaymentInstallment {
  id            String   @id @default(uuid()) @db.Uuid
  purchase_id   String   @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  payment_date  DateTime @db.Date
  note          String?  @db.Text
  entered_by    String   @db.Uuid
  is_deleted    Boolean  @default(false)
  deleted_by    String?  @db.Uuid
  deleted_at    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  purchase      Purchase @relation(fields: [purchase_id], references: [id])
  enterer       User     @relation("PaymentEnteredBy", fields: [entered_by], references: [id])
  deleter       User?    @relation("PaymentDeletedBy", fields: [deleted_by], references: [id])

  edit_logs     PaymentEditLog[]
}

model PaymentEditLog {
  id            String   @id @default(uuid()) @db.Uuid
  payment_id    String   @db.Uuid
  edited_by     String   @db.Uuid
  field_changed String   @db.VarChar(50)
  old_value     String?  @db.Text
  new_value     String?  @db.Text
  edited_at     DateTime @default(now())

  payment       PaymentInstallment @relation(fields: [payment_id], references: [id])
  editor        User               @relation(fields: [edited_by], references: [id])
}

model InventoryRequest {
  id               String   @id @default(uuid()) @db.Uuid
  branch_id        String   @db.Uuid
  vendor_id        String   @db.Uuid
  requested_by     String   @db.Uuid
  whatsapp_sent    Boolean  @default(false)
  whatsapp_sent_at DateTime?
  notes            String?  @db.Text
  created_at       DateTime @default(now())

  branch           Branch   @relation(fields: [branch_id], references: [id])
  vendor           Vendor   @relation(fields: [vendor_id], references: [id])
  requester        User     @relation(fields: [requested_by], references: [id])

  items            InventoryRequestItem[]
}

model InventoryRequestItem {
  id            String   @id @default(uuid()) @db.Uuid
  request_id    String   @db.Uuid
  item_name     String   @db.VarChar(150)
  quantity      Int
  created_at    DateTime @default(now())

  request       InventoryRequest @relation(fields: [request_id], references: [id])
}

model DailySale {
  id                 String   @id @default(uuid()) @db.Uuid
  branch_id          String   @db.Uuid
  entered_by         String   @db.Uuid
  sale_date          DateTime @db.Date
  total_sales_amount Decimal  @db.Decimal(12, 2)
  notes              String?  @db.Text
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  branch             Branch   @relation(fields: [branch_id], references: [id])
  enterer            User     @relation(fields: [entered_by], references: [id])

  @@unique([branch_id, sale_date])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(50)
  entity_id   String   @db.Uuid
  description String?  @db.Text
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now())
  ownerId     String   @db.Uuid

  user        User     @relation("AuditLogActor", fields: [user_id], references: [id])
  owner       User     @relation("OwnedAuditLogs", fields: [ownerId], references: [id])
}

model VendorOrder {
  id               String            @id @default(uuid()) @db.Uuid
  branch_id        String            @db.Uuid
  vendor_id        String            @db.Uuid
  requested_by     String            @db.Uuid
  notes            String?           @db.Text
  pdf_url          String?           @db.Text
  whatsapp_sent    Boolean           @default(false)
  whatsapp_sent_at DateTime?
  created_at       DateTime          @default(now())
  ownerId          String            @db.Uuid

  owner            User              @relation("OwnedVendorOrders", fields: [ownerId], references: [id])
  branch           Branch            @relation(fields: [branch_id], references: [id])
  vendor           Vendor            @relation(fields: [vendor_id], references: [id])
  requester        User              @relation("VendorOrderRequester", fields: [requested_by], references: [id])
  items            VendorOrderItem[]
}

model VendorOrderItem {
  id         String      @id @default(uuid()) @db.Uuid
  order_id   String      @db.Uuid
  item_name  String      @db.VarChar(150)
  quantity   Int
  image_url  String?     @db.Text
  created_at DateTime    @default(now())

  order      VendorOrder @relation(fields: [order_id], references: [id])
}

model DailyClosing {
  id              String         @id @default(uuid()) @db.Uuid
  branchId        String         @db.Uuid
  enteredBy       String         @db.Uuid
  closingDate     DateTime       @db.Date
  cashSales       Decimal        @db.Decimal(12,2)
  easypaisaSales  Decimal        @db.Decimal(12,2)
  totalSales      Decimal        @db.Decimal(12,2)
  registerTotal   Decimal        @db.Decimal(12,2)
  physicalToBox   Decimal        @db.Decimal(12,2)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  ownerId         String         @db.Uuid

  owner           User           @relation("OwnedDailyClosings", fields: [ownerId], references: [id])
  branch          Branch         @relation(fields: [branchId], references: [id])
  enterer         User           @relation("DailyClosingEnterer", fields: [enteredBy], references: [id])
  expenses        DailyExpense[]
  vendor_payments VendorPayment[]

  @@unique([branchId, closingDate])
}

model DailyExpense {
  id          String       @id @default(uuid()) @db.Uuid
  closingId   String       @db.Uuid
  description String       @db.VarChar(200)
  amount      Decimal      @db.Decimal(12,2)
  source      String       @db.VarChar(10)
  createdAt   DateTime     @default(now())
  ownerId     String       @db.Uuid
  vendorId    String?      @db.Uuid

  owner       User         @relation("OwnedDailyExpenses", fields: [ownerId], references: [id])
  closing     DailyClosing @relation(fields: [closingId], references: [id])
  vendor      Vendor?      @relation(fields: [vendorId], references: [id])
}

model CalBox {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String   @unique @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(12,2)
  updatedAt DateTime @updatedAt
  ownerId   String   @db.Uuid

  owner     User     @relation("OwnedCalBoxes", fields: [ownerId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])
}

model MonthlyClosing {
  id                   String   @id @default(uuid()) @db.Uuid
  branchId             String   @db.Uuid
  closedBy             String   @db.Uuid
  month                Int
  year                 Int
  totalCashSales       Decimal  @db.Decimal(12,2)
  totalEasypaisaSales  Decimal  @db.Decimal(12,2)
  totalSales           Decimal  @db.Decimal(12,2)
  totalExpenses        Decimal  @db.Decimal(12,2)
  totalSaleExpenses    Decimal  @db.Decimal(12,2)
  totalCalExpenses     Decimal  @db.Decimal(12,2)
  totalRegister        Decimal  @db.Decimal(12,2)
  totalPhysical        Decimal  @db.Decimal(12,2)
  netBachat            Decimal  @db.Decimal(12,2)
  daysRecorded         Int
  isLocked             Boolean  @default(true)
  closedAt             DateTime @default(now())
  createdAt            DateTime @default(now())
  ownerId              String   @db.Uuid

  owner                User     @relation("OwnedMonthlyClosings", fields: [ownerId], references: [id])
  branch               Branch   @relation(fields: [branchId], references: [id])
  closer               User     @relation("MonthlyClosingCloser", fields: [closedBy], references: [id])

  @@unique([branchId, month, year])
}

model VendorInventory {
  id          String   @id @default(uuid()) @db.Uuid
  vendorId    String   @db.Uuid
  branchId    String   @db.Uuid
  amount      Decimal  @db.Decimal(12,2)
  description String   @db.VarChar(300)
  date        DateTime @db.Date
  recordedBy  String   @db.Uuid
  createdAt   DateTime @default(now())
  ownerId     String   @db.Uuid

  owner       User     @relation("OwnedVendorInventories", fields: [ownerId], references: [id])
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  branch      Branch   @relation(fields: [branchId], references: [id])
  recorder    User     @relation("VendorInventoryRecorder", fields: [recordedBy], references: [id])
}

model VendorPayment {
  id          String        @id @default(uuid()) @db.Uuid
  vendorId    String        @db.Uuid
  branchId    String        @db.Uuid
  amount      Decimal       @db.Decimal(12,2)
  source      String        @db.VarChar(10)
  description String        @db.VarChar(300)
  date        DateTime      @db.Date
  recordedBy  String        @db.Uuid
  createdAt   DateTime      @default(now())
  ownerId     String        @db.Uuid
  closingId   String?       @db.Uuid

  owner       User          @relation("OwnedVendorPayments", fields: [ownerId], references: [id])
  vendor      Vendor        @relation(fields: [vendorId], references: [id])
  branch      Branch        @relation(fields: [branchId], references: [id])
  recorder    User          @relation("VendorPaymentRecorder", fields: [recordedBy], references: [id])
  closing     DailyClosing? @relation(fields: [closingId], references: [id])
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @db.VarChar(100)
  value     String   @db.Text
  ownerId   String   @db.Uuid
  updatedAt DateTime @updatedAt

  owner     User     @relation("OwnedSettings", fields: [ownerId], references: [id])

  @@unique([key, ownerId])
}
